{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "OxLER Oncology Agent Request",
  "type": "object",
  "required": [
    "institution_type",
    "condition_focus",
    "population_scope",
    "business_goals",
    "available_assets",
    "requested_capabilities"
  ],
  "properties": {
    "institution_type": { "type": "string", "minLength": 1 },
    "condition_focus": { "type": "string", "const": "oncologia" },
    "population_scope": { "type": "string", "minLength": 1 },
    "business_goals": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "minItems": 1
    },
    "available_assets": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "minItems": 1
    },
    "requested_capabilities": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "minItems": 1
    }
  },
  "additionalProperties": false
}
